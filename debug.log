":"class Solution {\\npublic:\\n    vector<vector<int>> filterOccupiedIntervals(vector<vector<int>>& occ, int frs, int fre) {\\n        vector<vector<int>> ans;\\n        int i,j;\\n        sort(occ.begin(),occ.end());\\n        for(auto x : occ){\\n            if(ans.empty()||x[0]>ans.back()[1]+1){\\n                ans.push_back(x);\\n            }else{\\n                ans.back()[1]=max(ans.back()[1],x[1]);\\n            }\\n        }\\n        vector<vector<int>> f;\\n        for(auto x : ans){\\n            int l = x[0],r=x[1];\\n            if(r<frs||l>fre){\\n                f.push_back({l,r});\\n            }else{\\n                if(l<frs){\\n                    f.push_back({l,frs-1});\\n                }\\n                if(r>fre){\\n                    f.push_back({fre+1,r});\\n                }\\n            }\\n        }\\n        return f;\\n    }\\n};","compare_result":"","title_slug":"filter-occupied-intervals","has_notes":false,"flag_type":1,"frontend_id":981},{"id":2048365703,"question_id":4348,"lang":"cpp","lang_name":"C++","time":"6\xc2\xa0days, 14\xc2\xa0hours","timestamp":1782614190,"status":10,"status_display":"Accepted","runtime":"188 ms","url":"/submissions/detail/2048365703/","is_pending":"Not Pending","title":"Maximum Total Sum of K Selected Elements","memory":"188 MB","code":"class Solution {\\npublic:\\n    long long maxSum(vector<int>& nums, int k, int mul) {\\n        int i = 0, j;\\n        long long ans = 0;\\n        sort(nums.rbegin(), nums.rend());\\n        while (i < k && mul > 1) {\\n            ans += 1LL * mul * nums[i];\\n            i++;\\n            mul--;\\n        }\\n        while(i<k){\\n            ans+=nums[i];\\n            i++;\\n        }\\n        return ans;\\n    }\\n};","compare_result":"","title_slug":"maximum-total-sum-of-k-selected-elements","has_notes":false,"flag_type":1,"frontend_id":980},{"id":2048358839,"question_id":4348,"lang":"cpp","lang_name":"C++","time":"6\xc2\xa0days, 14\xc2\xa0hours","times