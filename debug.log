s","memory":"32.1 MB","code":"class Solution:\\n    def maxIceCream(self, costs: List[int], coins: int) -> int:\\n        costs.sort()\\n        ans=0\\n        for i in range(len(costs)):\\n            if(coins>=costs[i]):\\n                coins-=costs[i]\\n                ans+=1\\n            else:\\n                break\\n        return ans            ","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-ice-cream-bars","has_notes":false,"flag_type":1,"frontend_id":935},{"id":2040390518,"question_id":4318,"lang":"cpp","lang_name":"C++","time":"1\xc2\xa0week, 6\xc2\xa0days","timestamp":1782009613,"status":10,"status_display":"Accepted","runtime":"165 ms","url":"/submissions/detail/2040390518/","is_pending":"Not Pending","title":"Valid Subarrays With Matching Sum Digits I","memory":"34.4 MB","code":"class Solution {\\npublic:\\n    int countValidSubarrays(vector<int>& nums, int x) {\\n        long long i,j,n=nums.size();\\n        vector<long long>pref(n+1,0);\\n        for(i=0;i<n;i++){\\n            pref[i+1]=pref[i]+nums[i];\\n        }\\n        long long ans =0;\\n        for(i=0;i<n;i++){\\n            for(j=i;j<n;j++){\\n                long long sum = pref[j+1]-pref[i];\\n                if(sum%10!=x)continue;\\n                long long t = sum;\\n                while(t>=10)t=t/10;\\n                if(t==x)ans++;\\n            }\\n        }\\n        return ans;\\n    }\\n};","compare_result":"","title_slug":"valid-subarrays-with-matching-sum-digits-i","has_notes":false,"flag_type":1,"frontend_id":934},{"id":2040377291,"question_id":4340,"lang":"cpp","lang_name":"C++","time":"1\xc2\xa0week, 6\xc2\xa0days","timestamp":1782009230,"status":10,"status_display":"Accepted","runtime":"4 ms","url":"/submissions/detail/2040377291/","is_pending":"Not Pending","title":"Maximum Manhattan Distance After All Moves","memory":"22.2 MB","code":"class Solution {\\npublic:\\n    int maxDistance(string s) {\\n        in