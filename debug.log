,freq=0;\\n            for(j=i;j<nums.size();j++){\\n                len++;\\n                if(nums[j]==target){\\n                    freq++;\\n                }\\n                if(freq>(len/2)){\\n                    ans++;\\n                 }\\n            }\\n        }\\n        return ans;\\n    }\\n};","compare_result":"","title_slug":"count-subarrays-with-majority-element-i","has_notes":false,"flag_type":1,"frontend_id":962},{"id":2045191103,"question_id":978,"lang":"cpp","lang_name":"C++","time":"1\xc2\xa0week, 2\xc2\xa0days","timestamp":1782355563,"status":10,"status_display":"Accepted","runtime":"20 ms","url":"/submissions/detail/2045191103/","is_pending":"Not Pending","title":"Valid Mountain Array","memory":"26.1 MB","code":"class Solution {\\npublic:\\n    bool validMountainArray(vector<int>& arr) {\\n        int n = arr.size();\\n        if (n < 3)\\n            return false;\\n\\n        int i = 0;\\n        while (i + 1 < n && arr[i] < arr[i + 1])\\n            i++;\\n        if (i == 0 || i == n - 1)\\n            return false;\\n        while (i + 1 < n && arr[i] > arr[i + 1])\\n            i++;\\n\\n        return i == n - 1;\\n    }\\n};","compare_result":"11111111111111111111111111111111111111111111111111111","title_slug":"valid-mountain-array","has_notes":false,"flag_type":1,"frontend_id":961},{"id":2044143933,"question_id":2953,"lang":"cpp","lang_name":"C++","time":"1\xc2\xa0week, 3\xc2\xa0days","timestamp":1782278457,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/2044143933/","is_pending":"Not Pending","title":"Count Pairs of Points With Distance k","memory":"N/A","code":"class Solution {\\npublic:\\n    int countPairs(vector<vector<int>>& coordinates, int k) {\\n        int ans = 0;\\n\\n        for (int i = 0; i < coordinates.size(); i++) {\\n            for (int j = i + 1; j < coordinates.size(); j++) {\\n                if (((coordinates[i][0] ^ coordinates[j][0]) +\\n                    