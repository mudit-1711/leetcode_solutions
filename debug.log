l":"/submissions/detail/2054801445/","is_pending":"Not Pending","title":"Check if Any Element Has Prime Frequency","memory":"24.2 MB","code":"class Solution {\\npublic:\\n    bool isprime(int& x){\\n        if(x<2){\\n            return false;\\n        }\\n        for(int i=2;i*i<=x;i++){\\n            if(x%i==0)return false;\\n        }\\n        return true;\\n    }\\n    bool checkPrimeFrequency(vector<int>& nums) {\\n        map<int,int>mpp;\\n        for(auto x : nums){\\n            mpp[x]++;\\n        }\\n        for(auto x : mpp){\\n            if(isprime(x.second)){\\n                return true;\\n            }\\n        }\\n        return false;\\n    }\\n};","compare_result":"","title_slug":"check-if-any-element-has-prime-frequency","has_notes":false,"flag_type":1,"frontend_id":998},{"id":2054539273,"question_id":4186,"lang":"cpp","lang_name":"C++","time":"1\xc2\xa0day, 6\xc2\xa0hours","timestamp":1783074216,"status":10,"status_display":"Accepted","runtime":"26 ms","url":"/submissions/detail/2054539273/","is_pending":"Not Pending","title":"Count Residue Prefixes","memory":"19.8 MB","code":"class Solution {\\npublic:\\n    int residuePrefixes(string s) {\\n        int i,j=0,n=s.length();\\n        string temp=\\"\\";\\n        for(i=0;i<n;i++){\\n            temp+=s[i];\\n            set<char>st;\\n            for(auto c : temp){\\n                st.insert(c);\\n            }\\n            if(st.size()==(temp.size()%3)){\\n                j+=1;\\n            }\\n        }\\n        return j;\\n    }\\n};","compare_result":"","title_slug":"count-residue-prefixes","has_notes":false,"flag_type":1,"frontend_id":997},{"id":2053409029,"question_id":4073,"lang":"cpp","lang_name":"C++","time":"2\xc2\xa0days, 5\xc2\xa0hours","timestamp":1782988964,"status":10,"status_display":"Accepted","runtime":"114 ms","url":"/submissions/detail/2053409029/","is_pending":"Not Pending","title":"Lexicographically Smallest String After Reverse","memory":"92 MB","code":"class Solution {\\npublic:\\n    string lexSmallest(string s) {\\n        string ans = s;\\n        string orginal = s;\\n        for (int k = 1; k <= s.size(); k++) {\\n            string temp = orginal;\\n            reverse(temp.begin(), temp.begin() + k);\\n            ans = min(ans, temp);\\n            temp = orginal;\\n            reverse(temp.end() - k, temp.end());\\n            ans = min(ans, temp);\\n            temp = orginal;\\n        }\\n        return ans;\\n    }\\n};","compare_result":"","title_slug":"lexicographically-smallest-string-after-reverse","has_notes":false,"flag_type":1,"frontend_id":996},{"id":2053228366,"question_id":8,"lang":"cpp","lang_name":"C++","time":"2\xc2\xa0days, 8\xc2\xa0hours","timestamp":1782979059,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2053228366/","is_pending":"Not Pending","title":"String to Integer (atoi)","memory":"9.1 MB","code":"class Solution {\\npublic:\\n    int myAtoi(string s) {\\n        int i = 0, n = s.length();\\n        while (i < n && s[i] == \' \') {\\n            i++;\\n        }\\n        int sign = 1;\\n        if (i < n && (s[i] == \'+\' || s[i] == \'-\')) {\\n            if (s[i] == \'-\') {\\n                sign = -1;\\n            }\\n            i++;\\n        }\\n        long long num = 0;\\n        while (i < n && isdigit(s[i])) {\\n            num = num * 10 + s[i] - \'0\';\\n            if (sign == 1 && num > INT_MAX)\\n                return INT_MAX;\\n            if (sign == -1 && -num < INT_MIN)\\n                return INT_MIN;\\n                i++;\\n        }\\n        return sign*num;\\n    }\\n};","compare_result":"","title_slug":"string-to-integer-atoi","has_notes":false,"flag_type":1,"frontend_id":995},{"id":2053180590,"question_id":1,"lang":"cpp","lang_name":"C++","time":"2\xc2\xa0days, 9\xc2\xa0hours","timestamp":1782976128,"status":10,"status_display":"Accepted","runtime":"44 ms","url":"/submissions/detail/2053180590/","is_pending":"Not Pending","title":"Two Sum","memory":"14.1 MB","code":"class Solution {\\npublic:\\n    vector<int> twoSum(vector<int>& nums, int target) {\\n      int i,j,n;\\n        for(i=0;i<nums.size();i++){\\n            for(j=i+1;j<nums.size();j++){\\n                if(nums[i]+nums[j]==target){\\n                    return {i,j};\\n                }\\n            }\\n        }\\n        return{};\\n    }\\n};","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"two-sum","has_notes":false,"flag_type":1,"frontend_id":994},{"id":2052183487,"question_id":2767,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0days, 6\xc2\xa0hours","timestamp":1782899031,"status":10,"status_display":"Accepted","runtime":"7 ms","url":"/submissions/detail/2052183487/","is_pending":"Not Pending","title":"Maximum Sum With Exactly K Elements ","memory":"19.3 MB","code":"class Solution:\\n    def maximizeSum(self, nums: List[int], k: int) -> int:\\n        ans=0\\n        nums.sort()\\n        nums.reverse()\\n        while k>0:\\n            ans+=nums[0]\\n            nums[0]+=1\\n            k-=1\\n        return ans    ","compare_result":"","title_slug":"maximum-sum-with-exactly-k-elements","has_notes":false,"flag_type":1,"frontend_id":993},{"id":2050758118,"question_id":1460,"lang":"python3","lang_name":"Python3","time":"4\xc2\xa0days, 11\xc2\xa0hours","timestamp":1782796927,"status":10,"status_display":"Accepted","runtime":"91 ms","url":"/submissions/detail/2050758118/","is_pending":"Not Pending","title":"Number of Substrings Containing All Three Characters","memory":"19.3 MB","code":"class Solution:\\n    def numberOfSubstrings(self, s: str) -> int:\\n        n = len(s)\\n        cnt = [0, 0, 0]\\n        left = 0\\n        ans = 0\\n        for right in range(n):\\n            cnt[ord(s[right]) - ord(\'a\')] += 1\\n            while cnt[0] > 0 and cnt[1] > 0 and cnt[2] > 0:\\n                ans += n - right\\n                cnt[ord(s[left]) - ord(\'a\')] -= 1\\n                left += 1\\n        return ans","compare_result":"111111111111111111111111111111111111111111111111111111","title_slug":"number-of-substrings-containing-all-three-characters","has_notes":false,"flag_type":1,"frontend_id":992},{"id":2050748019,"question_id":1460,"lang":"cpp","lang_name":"C++","time":"4\xc2\xa0days, 11\xc2\xa0hours","timestamp":1782796396,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/2050748019/","is_pending":"Not Pending","title":"Number of Substrings Containing All Three Characters","memory":"N/A","code":"class Solution {\\npublic:\\n    int numberOfSubstrings(string s) {\\n        int i,j,ans=0;\\n        for(i=0;i<s.size();i++){\\n            int a=0,b=0,c=0;\\n            for(j=i;j<s.size();j++){\\n                if (s[j] == \'a\') a++;\\n                else if (s[j] == \'b\') b++;\\n                else c++;\\n                if (a && b && c)\\n                    ans++;\\n            }\\n        }\\n        return ans;\\n    }\\n};","compare_result":"111111111111111111111111111111111111111111111111000000","title_slug":"number-of-substrings-containing-all-three-characters","has_notes":false,"flag_type":1,"frontend_id":991},{"id":2049906703,"question_id":216,"lang":"cpp","lang_name":"C++","time":"5\xc2\xa0days, 6\xc2\xa0hours","timestamp":1782727430,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2049906703/","is_pending":"Not Pending","title":"Combination Sum III","memory":"9.1 MB","code":"class Solution {\\npublic:\\n    void f(vector<vector<int>>& ans, int k, int n, vector<int>& v, int idx, int sum) {\\n        if (v.size()== k && sum == n) {\\n            ans.push_back(v);\\n            return;\\n        }\\n        if(idx>9)return ;\\n        v.push_back(idx);\\n        f(ans,k,n,v,idx+1,sum+idx);\\n        v.pop_back();\\n        f(ans,k,n,v,idx+1,sum);\\n    }\\n    vector<vector<int>> combinationSum3(int k, int n) {\\n        vector<vector<int>>ans;\\n        vector<int>v;\\n        f(ans,k,n,v,1,0);\\n        return ans;\\n    }\\n};","compare_result":"1111111111111111111","title_slug":"combination-sum-iii","has_notes":false,"flag_type":1,"frontend_id":990},{"id":2049689464,"question_id":90,"lang":"cpp","lang_name":"C++","time":"5\xc2\xa0days, 9\xc2\xa0hours","timestamp":1782715180,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2049689464/","is_pending":"Not Pending","title":"Subsets II","memory":"10.4 MB","code":"class Solution {\\npublic:\\n    void f(vector<vector<int>>&ans,vector<int>&nums,vector<int>&v,int idx){\\n        if(idx==nums.size()){\\n            ans.push_back(v);\\n            return ;\\n        }\\n        v.push_back(nums[idx]);\\n        f(ans,nums,v,idx+1);\\n        v.pop_back();\\n        int next=idx+1;\\n        while(next<nums.size()&&nums[idx]==nums[next]){\\n            next++;\\n        }\\n        f(ans,nums,v,next);\\n    }\\n    vector<vector<int>> subsetsWithDup(vector<int>& nums) {\\n        vector<vector<int>> ans;\\n        vector<int>v;\\n        sort(nums.begin(),nums.end());\\n        f(ans,nums,v,0);\\n        return ans;\\n    }\\n};","compare_result":"11111111111111111111","title_slug":"subsets-ii","has_notes":false,"flag_type":1,"frontend_id":989},{"id":2049682886,"question_id":77,"lang":"cpp","lang_name":"C++","time":"5\xc2\xa0days, 10\xc2\xa0hours","timestamp":1782714855,"status":10,"status_display":"Accepted","runtime":"67 ms","url":"/submissions/detail/2049682886/","is_pending":"Not Pending","title":"Combinations","memory":"110.1 MB","code":"class Solution {\\npublic:\\n    void f(vector<vector<int>>& ans, vector<int>& v, int idx, int n, int k) {\\n        if(v.size() == k){\\n            ans.push_back(v);\\n            return;\\n        }\\n        if(idx > n)\\n            return;\\n        v.push_back(idx);\\n        f(ans, v, idx + 1, n, k);\\n        v.pop_back();\\n        f(ans, v, idx + 1, n, k);\\n    }\\n    vector<vector<int>> combine(int n, int k) {\\n        vector<vector<int>> ans;\\n        vector<int> v;\\n        f(ans, v, 1, n, k);\\n        return ans;\\n    }\\n};","compare_result":"111111111111111111111111111","title_slug":"combinations","has_notes":false,"flag_type":1,"frontend_id":988},{"id":2049678089,"question_id":40,"lang":"cpp","lang_name":"C++","time":"5\xc2\xa0days, 10\xc2\xa0hours","timestamp":1782714619,"status":10,"status_display":"Accepted","runtime":"110 ms","url":"/submissions/detail/2049678089/","is_pending":"Not Pending","title":"Combination Sum II","memory":"105.4 MB","code":"class Solution {\\npublic:\\n    void f(vector<vector<int>>& ans, vector<int>& v, int idx, int sum,\\n           vector<int> cand, int targ) {\\n        if (sum == targ) {\\n            ans.push_back(v);\\n            return;\\n        }\\n        if (idx == cand.size() || sum > targ)\\n            return;\\n        v.push_back(cand[idx]);\\n        f(ans, v, idx + 1, sum + cand[idx], cand, targ);\\n        v.pop_back();\\n        int next = idx + 1;\\n        while (next < cand.size() && cand[next] == cand[idx])\\n            next++;\\n        f(ans, v, next, sum, cand, targ);\\n    }\\n    vector<vector<int>> combinationSum2(vector<int>& candidates, int target) {\\n        sort(candidates.begin(), candidates.end());\\n        vector<vector<int>> ans;\\n        vector<int> v;\\n        f(ans, v, 0, 0, candidates, target);\\n        return ans;\\n    }\\n};","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"combination-sum-ii","has_notes":false,"flag_type":1,"frontend_id":987},{"id":2049672045,"question_id":39,"lang":"cpp","lang_name":"C++","time":"5\xc2\xa0days, 10\xc2\xa0hours","timestamp":1782714318,"status":10,"status_display":"Accepted","runtime":"71 ms","url":"/submissions/detail/2049672045/","