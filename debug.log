,"status_display":"Accepted","runtime":"456 ms","url":"/submissions/detail/2035087350/","is_pending":"Not Pending","title":"K-diff Pairs in an Array","memory":"16.8 MB","code":"class Solution {\\npublic:\\n    int findPairs(vector<int>& nums, int k) {\\n        set<pair<int,int>> s;\\n\\n        for (int i = 0; i < nums.size(); i++) {\\n            for (int j = i + 1; j < nums.size(); j++) {\\n                if (abs(nums[i] - nums[j]) == k) {\\n                    s.insert({min(nums[i], nums[j]),\\n                              max(nums[i], nums[j])});\\n                }\\n            }\\n        }\\n\\n        return s.size();\\n    }\\n};","compare_result":"111111111111111111111111111111111111111111111111111111111111","title_slug":"k-diff-pairs-in-an-array","has_notes":false,"flag_type":1,"frontend_id":908},{"id":2035086788,"question_id":532,"lang":"python3","lang_name":"Python3","time":"2\xc2\xa0weeks, 4\xc2\xa0days","timestamp":1781608955,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/2035086788/","is_pending":"Not Pending","title":"K-diff Pairs in an Array","memory":"N/A","code":"class Solution:\\n    def findPairs(self, nums: List[int], k: int) -> int:\\n        s=set()\\n        for i in range(len(nums)):\\n            for j in range(len(nums)):\\n                if i!=j and abs(nums[i]-nums[j])==k :\\n                    a = min(nums[i], nums[j])\\n                    b = max(nums[i], nums[j])\\n                    s.add((a, b))\\n        return len(s)            \\n","compare_result":"111111111111111111111111111111111111111111111111111100000000","title_slug":"k-diff-pairs-in-an-array","has_notes":false,"flag_type":1,"frontend_id":907},{"id":2035076081,"question_id":12,"lang":"cpp","lang_name":"C++","time":"2\xc2\xa0weeks, 4\xc2\xa0days","timestamp":1781608280,"status":10,"status_display":"Accepted","runtime":"37 ms","url":"/submissions/detail/2035076081/","is_pending":"Not Pending","title":"Integer to Roman","memory":"25.7 MB","code":"class Solution {\\npublic:\\n    string intToRoman(int num) {\\n        unordered_map<int, string> mp = {\\n            {1, \\"I\\"},     {2, \\"II\\"},     {3, \\"III\\"},  {4, \\"IV\\"},\\n            {5, \\"V\\"},     {6, \\"VI\\"},     {7, \\"VII\\"},  {8, \\"VIII\\"},\\n            {9, \\"IX\\"},    {10, \\"X\\"},     {20, \\"XX\\"},  {30, \\"XXX\\"},\\n            {40, \\"XL\\"},   {50, \\"L\\"},     {60, \\"LX\\"},  {70, \\"LXX\\"},\\n            {80, \\"LXXX\\"}, {90, \\"XC\\"},    {100, \\"C\\"},  {200, \\"CC\\"},\\n            {300, \\"CCC\\"}, {400, \\"CD\\"},   {500, \\"D\\"},  {600, \\"DC\\"},\\n            {700, \\"DCC\\"}, {800, \\"DCCC\\"}, {900, \\"CM\\"}, {1000, \\"M\\"},\\n            {2000, \\"MM\\"}, {3000, \\"MMM\\"}};\\n        int i, j;\\n        string s = to_string(num);\\n        vector<int> v;\\n        int pos = 1;\\n        for (i = s.size() - 1; i >= 0; i--) {\\n            v.push_back(pos * (s[i] - \'0\'));\\n            pos *= 10;\\n        }\\n        string ans = \\"\\";\\n        reverse(v.begin(), v.end());\\n        for (int x : v) {\\n            ans += mp[x];\\n        }\\n        return ans;\\n    }\\n};","compare_result":"","title_slug":"integer-to-roman","has_notes":false,"flag_type":1,"frontend_id":906}],"has_next":true,"last_key":""}'
